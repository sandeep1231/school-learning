# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Google Gemini ---
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=text-embedding-004

# --- Upstash Redis (rate limits + caching) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Notifications ---
RESEND_API_KEY=
GUPSHUP_API_KEY=
GUPSHUP_SOURCE_NUMBER=
MSG91_AUTH_KEY=
MSG91_OTP_TEMPLATE_ID=

# --- Observability ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Used by @sentry/nextjs build-time source-map upload (optional for self-hosted).
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=change-me

# --- Transactional email (Resend HTTP API) ---
# Leave RESEND_API_KEY empty in dev — the mailer logs instead of sending.
RESEND_API_KEY=
MAIL_FROM="Sikhya Sathi <noreply@sikhyasathi.app>"
MAIL_REPLY_TO=support@sikhyasathi.app

# --- Billing (Phase 13 UPI QR) ---
# Merchant UPI virtual payment address. Checkout refuses to mint orders if blank.
UPI_VPA=
UPI_PAYEE_NAME=Sikhya Sathi
# Comma-separated list of admin emails (case-insensitive). Admins gain access
# to /admin/payments and the verify endpoint.
ADMIN_EMAILS=
